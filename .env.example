# LangSmith API key — lsv2_pt_...
LANGSMITH_API_KEY=

# Cloudflare bypass — required when langsmith.blitzy.com sits behind a CF challenge.
# Grab from: browser DevTools > Application > Cookies > langsmith.blitzy.com
CF_CLEARANCE=

# Must exactly match the User-Agent of the browser session that issued CF_CLEARANCE.
# Grab from: DevTools > Network > any request > Request Headers > user-agent
BROWSER_UA=
